# AgentWorkingMemory configuration
# Copy to .env and fill in values

# API key for HTTP auth (optional — leave empty for no auth)
# AWM_API_KEY=your-secret-key-here

# Database path (default: memory.db)
AWM_DB_PATH=memory.db

# HTTP port (default: 8400)
AWM_PORT=8400

# MCP agent ID (default: claude-code)
# AWM_AGENT_ID=claude-code

# Embedding model (default: Xenova/all-MiniLM-L6-v2)
# AWM_EMBED_MODEL=Xenova/all-MiniLM-L6-v2
# AWM_EMBED_DIMS=384

# Reranker model (default: Xenova/ms-marco-MiniLM-L-6-v2)
# AWM_RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
